{
  "_cosplay_section": {
    "description": "=== 女装图片保存 ===",
    "type": "text",
    "invisible": true
  },
  "save_cosplay_images": {
    "description": "开启女装图片保存",
    "type": "bool",
    "default": true,
    "hint": "✅ 开启：自动识别并保存群友的女装图片到独立目录\n❌ 关闭：不保存女装图片\n\n📁 保存路径：数据目录/cosplay/群号/群员 QQ 号_QQ 名/图片文件"
  },
  "cosplay_vision_provider_id": {
    "description": "女装识别专用模型",
    "type": "string",
    "hint": "留空则使用默认视觉模型，建议使用识别能力较强的模型",
    "_special": "select_provider"
  },
  "cosplay_detection_threshold": {
    "description": "女装识别阈值",
    "type": "float",
    "default": 0.6,
    "slider": {
      "min": 0.3,
      "max": 0.9,
      "step": 0.05
    },
    "hint": "识别阈值越低越容易判定为女装（宽松），越高越严格。建议 0.5-0.7"
  },
  "ignore_gif": {
    "description": "忽略 GIF 图片",
    "type": "bool",
    "default": false,
    "hint": "✅ 开启：跳过所有 GIF 图片，不检测不保存\n❌ 关闭：正常处理 GIF 图片（会提取关键帧识别）"
  },

  "_model_section": {
    "description": "=== 模型配置 ===",
    "type": "text",
    "invisible": true
  },
  "vision_provider_id": {
    "description": "视觉模型（用于图片分类）",
    "type": "string",
    "hint": "留空则自动使用 AstrBot 全局配置的「图片描述模型」(default_image_caption_provider_id)",
    "_special": "select_provider"
  },

  "_advanced_section": {
    "description": "=== 高级配置 ===",
    "type": "text",
    "invisible": true
  },
  "max_reg_num": {
    "description": "最大缓存数量",
    "type": "int",
    "default": 100,
    "hint": "图片检测缓存上限"
  },
  "content_filtration": {
    "description": "内容审核",
    "type": "bool",
    "default": false,
    "hint": "过滤不当图片"
  },
  "image_processing_cooldown": {
    "description": "图片处理冷却时间/秒",
    "type": "int",
    "default": 10,
    "hint": "两次图片处理之间的最小间隔（秒）。0=不限制"
  },

  "_smtp_section": {
    "description": "=== SMTP 邮件推送 ===",
    "type": "text",
    "invisible": true
  },
  "smtp": {
    "description": "SMTP 邮件配置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "启用邮件推送",
        "type": "bool",
        "default": false,
        "hint": "✅ 开启：每天定时发送日报到邮箱\n❌ 关闭：不发送邮件"
      },
      "smtp_server": {
        "description": "SMTP 服务器",
        "type": "string",
        "default": "",
        "hint": "例如：smtp.qq.com, smtp.gmail.com, smtp.163.com"
      },
      "smtp_port": {
        "description": "SMTP 端口",
        "type": "int",
        "default": 587,
        "hint": "TLS 加密端口：587（推荐）或 465；非加密：25"
      },
      "sender_email": {
        "description": "发件人邮箱",
        "type": "string",
        "default": "",
        "hint": "发送邮件的邮箱地址"
      },
      "sender_password": {
        "description": "邮箱授权码",
        "type": "string",
        "default": "",
        "hint": "邮箱授权码或密码（非登录密码，需在邮箱设置中获取）"
      },
      "receiver_email": {
        "description": "收件人邮箱",
        "type": "string",
        "default": "",
        "hint": "接收日报的邮箱地址"
      },
      "use_tls": {
        "description": "使用 TLS 加密",
        "type": "bool",
        "default": true,
        "hint": "✅ 开启：使用 TLS 加密连接（推荐）\n❌ 关闭：不使用加密"
      },
      "send_time": {
        "description": "发送时间",
        "type": "string",
        "default": "08:00",
        "hint": "每日发送时间（24 小时制），例如：08:00, 20:00"
      }
    }
  }
}
